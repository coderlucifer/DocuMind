# =============================================================================
# DocuMind Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── LLM Configuration ──────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind_secret_2024
POSTGRES_DB=documind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://documind:documind_secret_2024@postgres:5432/documind

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── FastAPI ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Search Configuration ───────────────────────────────────────────────────
SEMANTIC_SEARCH_WEIGHT=0.6
BM25_SEARCH_WEIGHT=0.4
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.7

# ─── Chunking Configuration ─────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
PARENT_CHUNK_SIZE=2048
PARENT_CHUNK_OVERLAP=200

# ─── Agent Configuration ────────────────────────────────────────────────────
MAX_RETRIEVAL_ITERATIONS=3
HALLUCINATION_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.75

# ─── Cache Configuration ────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.92
